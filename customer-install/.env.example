# SendPrint Bridge — configuratie
# Kopieer dit bestand naar .env en pas de waarden aan.
# install.bat doet dit automatisch voor je.

# Wachtwoord voor het dashboard (eerste keer inloggen).
# Verander dit later via het dashboard zelf.
ADMIN_PASSWORD=verander-mij

# Welke versie van de bridge gebruiken? Default is :latest (auto-update via Watchtower).
# Wil je vast op één versie zitten? Zet bv. ghcr.io/OWNER/REPO:1.2.3
SENDPRINT_IMAGE=ghcr.io/OWNER/REPO:latest

# Op welke poort luistert het dashboard? Default 8080.
# Verander dit alleen als 8080 al in gebruik is op deze PC.
SENDPRINT_PORT=8080
